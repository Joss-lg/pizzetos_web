---
// src/components/Sections/Sucursales.astro

const branches = [
  {
    id: "miraflores",
    name: "Pizzetos Miraflores",
    phone: "55 8445 7355",
    whatsapp: "5215584457355",
    address: "Carretera Chalco Manzana 005, Miraflores, 56645 San Mateo Tezoquipan, Méx.",
    mapSrc: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3766.19519124436!2d-98.8228361!3d19.2268527!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce238804835549%3A0x43851c3376b61468!2sPizzeto%20Pizza%20-%20Miraflores!5e0!3m2!1ses-419!2smx!4v1715000000000!5m2!1ses-419!2smx",
    googleMapsLink: "https://www.google.com/maps/search/?api=1&query=Pizzeto+Pizza+-+Miraflores&query_place_id=ChIJSVWDBIgjzoURaBS2djMchUM"
  },
];
---

<section id="sucursales" class="py-24 relative overflow-hidden">
  
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="font-serif italic text-4xl md:text-5xl text-neutral-900 mb-4">
        Encuéntranos
      </h2>
      <p class="text-neutral-500 max-w-2xl mx-auto text-sm md:text-base uppercase tracking-widest">
        Visítanos en nuestra sucursal o pide a domicilio.
      </p>
      <div class="w-24 h-1 bg-amber-500 mx-auto mt-6 rounded-full"></div>
    </div>

    {/* Contenedor Principal de la Sucursal */}
    {branches.map((sucursal) => (
      <div class="group bg-white border border-black/5 rounded-[2rem] overflow-hidden hover:border-amber-500/30 transition-all duration-500 hover:shadow-2xl shadow-sm flex flex-col lg:flex-row">
        
        {/* LADO IZQUIERDO: INFORMACIÓN */}
        <div class="p-8 md:p-12 lg:w-1/2 flex flex-col relative z-10">
          <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <div class="flex justify-between items-start mb-8 relative">
            <div>
              <h3 class="text-3xl md:text-4xl font-serif text-neutral-900 font-bold mb-2">{sucursal.name}</h3>
              <div class="flex items-center gap-2 text-green-600 text-xs font-bold tracking-wider uppercase">
                <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse"></span>
                Disponible
              </div>
            </div>
            <div class="bg-black/5 p-4 rounded-2xl text-amber-600 border border-black/5 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
          </div>

          <div class="space-y-6 mb-10 flex-1 relative">
            <div class="flex items-start gap-4 text-neutral-500 group-hover:text-neutral-800 transition-colors">
                <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.806-.982l-4.747-2.374m0 0l-6 3m6-3V5" />
                    </svg>
                </div>
                <p class="text-base leading-relaxed">{sucursal.address}</p>
            </div>

            <div class="flex items-center gap-4 text-neutral-500 group-hover:text-neutral-900 transition-colors">
                <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                </div>
                <span class="text-lg font-bold tracking-wide">{sucursal.phone}</span>
            </div>
          </div>

          <div class="relative">
            <a 
              href={`https://wa.me/${sucursal.whatsapp}`} 
              target="_blank" 
              class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-6 rounded-2xl shadow-xl hover:shadow-green-500/20 hover:-translate-y-1 transition-all flex items-center justify-center gap-3 text-lg"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.013-.967-.255-.099-.44-.15-.624.15-.183.299-.715.867-.876 1.05-.161.179-.322.199-.619.05-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.248-.57-.397M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0m0 22c-5.523 0-10-4.477-10-10S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10"/></svg>
              Pedir por WhatsApp
            </a>
          </div>
        </div>

        {/* LADO DERECHO: MAPA */}
        <div class="lg:w-1/2 min-h-[400px] relative overflow-hidden">
          <iframe 
            src={sucursal.mapSrc} 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="absolute inset-0 grayscale hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100"
          ></iframe>
          
          <a 
            href={sucursal.googleMapsLink} 
            target="_blank" 
            class="absolute bottom-6 right-6 bg-neutral-900 text-white font-bold px-6 py-3 rounded-xl shadow-2xl hover:bg-amber-600 transition-all z-20 flex items-center gap-2"
          >
            Abrir en Google Maps 
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

      </div>
    ))}
  </div>
</section>

<script>
  // Lógica para desplegar el mapa suavemente
  const mapButtons = document.querySelectorAll('.map-toggle-btn');

  mapButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target') || "";
      
      const mapContainer = document.getElementById(targetId);
      const btnText = btn.querySelector('.btn-text');

      if (mapContainer) {
        if (mapContainer.style.maxHeight) {
          // Cerrar
          mapContainer.style.maxHeight = ""; 
          mapContainer.classList.remove('opacity-100');
          mapContainer.classList.add('opacity-50');
          if(btnText) btnText.textContent = "Ver Mapa";
        } else {
          // Abrir
          mapContainer.style.maxHeight = "300px"; 
          mapContainer.classList.remove('opacity-50');
          mapContainer.classList.add('opacity-100');
          if(btnText) btnText.textContent = "Ocultar Mapa";
        }
      }
    });
  });
</script>