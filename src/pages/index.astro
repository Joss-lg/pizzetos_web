---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import MenuCard from '../components/Menu/MenuCard.astro';
import SizeSelector from '../components/Menu/SizeSelector.jsx';
import { menuItems } from '../data/menuData.js'; 
import ProductModal from '../components/Menu/ProductModal.jsx';
import CreaTuPizza from '../components/Menu/CreaTuPizza.jsx'; 
import Sucursales from '../components/Sections/Sucursales.astro';

const allItems = menuItems || [];

// 1. SEPARAMOS LOS DATOS
const pizzas = allItems.filter(i => i.category === 'Pizzas' || i.category === 'Especialidades del Mar');
const paquetes = allItems.filter(i => i.category === 'Paquetes');
const snacks = allItems.filter(i => i.category === 'Snacks');
const bebidas = allItems.filter(i => i.category === 'Bebidas');

// Unimos todo lo "Extra" para la vista de complementos
const extras = [...paquetes, ...snacks, ...bebidas];
// Categorías para los botones de filtro de extras
const extraCategories = ["Todos", "Paquetes", "Snacks", "Bebidas"];
---

<Layout title="Pizzetos">
  <main class="bg-[#f5f5f4] min-h-screen pb-0 relative font-body pt-16 md:pt-28 overflow-x-hidden text-neutral-800">
    
    {/* Fondo decorativo */}
<div class="absolute top-20 md:top-28 left-1/2 -translate-x-1/2 w-full max-w-[350px] h-[250px] md:h-[300px] bg-amber-500/30 rounded-full blur-[60px] md:blur-[100px] pointer-events-none z-0"></div>

<section class="pt-4 pb-4 text-center px-4 relative z-10 flex flex-col items-center gap-3">
    
    <div class="animate-fade-in-down flex justify-center">
         <img 
            src="/3.png" 
            alt="Logo Pizzetos" 
            class="h-48 md:h-80 w-auto object-contain drop-shadow-sm"
         />
    </div>

</section>
    {/* --- PANTALLA PRINCIPAL --- */}
    <div id="screen-sizes" class="transition-all duration-500 opacity-100 transform translate-x-0 pt-2 md:pt-4 relative z-10 px-4">
      
      {/* 1. SELECTOR DE TAMAÑO (Encabezado) */}
      <SizeSelector client:load />
      
      {/* 2. SECCIÓN EXTRAS (Paquetes/Snacks/Bebidas - Ahora en medio) */}
      <section class="relative z-10 max-w-7xl mx-auto px-3 md:px-4 mt-10 md:mt-14 mb-8">
  
        <h2 class="text-2xl md:text-3xl font-serif text-neutral-900 italic mb-6 text-center">
          Complementos
        </h2>

        {/* Botones de Filtro Extras */}
        <div class="flex justify-center gap-2 mb-8 flex-wrap">
          {extraCategories.map(cat => (
            <button
              class="extra-cat-btn px-4 py-2 rounded-full border border-black/10 text-[10px] md:text-xs font-bold uppercase text-neutral-500 hover:text-neutral-900 hover:border-amber-500 transition-all"
              data-filter={cat}
            >
              {cat}
            </button>
          ))}
        </div>

        {/* Grid de Extras */}
        <div id="extras-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-6 pb-4">
          {extras.map((item) => (
            <div class="extra-item" data-category={item.category}>
              <MenuCard 
                id={item.id}
                name={item.name}
                description={item.description}
                price={item.price}
                image={item.image}
                category={item.category}
                prices={item.prices}
                type={item.type}
              />
            </div>
          ))}
        </div>

      </section>

      {/* Separador Visual */}
      <div class="max-w-4xl mx-auto border-t border-black/5 my-8"></div>

      {/* 3. COMPONENTE CREA TU PIZZA (Ahora al final) */}
      <section class="relative z-20 max-w-5xl mx-auto px-4 mb-20">
         <div class="text-center mb-6">
             <span class="text-xs font-bold tracking-widest text-amber-600 uppercase">¿Algo único?</span>
             <h2 class="text-2xl font-serif italic text-neutral-900">Arma tu propia Pizza</h2>
         </div>
         <CreaTuPizza client:visible />
      </section>

    </div>

    {/* --- PANTALLA 2: GRID DE SABORES DE PIZZA --- */}
    <div 
      id="screen-flavors" 
      class="hidden opacity-0 transform translate-x-0 transition-all duration-500 w-full max-w-7xl mx-auto px-2 pt-0 md:pt-6 pb-32 relative z-10"
    >
        {/* BARRA PEGAJOSA */}
        <div class="sticky top-0 md:top-20 z-40 bg-[#f5f5f4]/95 backdrop-blur-xl border-b border-black/5 shadow-lg -mx-4 px-4 py-3 mb-6 transition-all">
            <div class="flex gap-3 items-center mb-3">
                <button id="btn-back-sizes" class="flex-shrink-0 w-10 h-10 rounded-full bg-black/5 flex items-center justify-center text-neutral-800 hover:bg-amber-500 hover:text-black transition-all group">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <div class="relative flex-grow">
                    <input type="text" id="pizza-search" placeholder="Buscar sabor..." class="w-full bg-white border border-black/10 rounded-full py-2.5 pl-10 pr-4 text-neutral-800 text-sm focus:outline-none focus:border-amber-500 focus:bg-white transition-all placeholder-neutral-400"/>
                    <svg class="absolute left-3.5 top-3 h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
            </div>
            <div class="flex items-center justify-between gap-4">
                <div class="flex gap-2 overflow-x-auto pb-1 w-full scrollbar-hide mask-fade-right">
                    <button class="cat-btn active flex-shrink-0 text-xs py-1.5 px-4" data-filter="all">Todas</button>
                    <button class="cat-btn flex-shrink-0 text-xs py-1.5 px-4" data-filter="Pizzas">Clásicas</button>
                    <button class="cat-btn flex-shrink-0 text-xs py-1.5 px-4" data-filter="Especialidades del Mar">Del Mar</button>
                </div>
                <div class="hidden sm:block text-right flex-shrink-0">
                    <span class="text-[10px] text-neutral-500 uppercase tracking-widest block">Tamaño</span>
                    <span id="display-selected-size" class="text-sm font-serif text-amber-600 italic font-bold">--</span>
                </div>
            </div>
        </div>

        {/* GRID DE PIZZAS */}
        <div id="pizza-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pb-32 w-full">
            {pizzas.map((item) => (
                <div class="pizza-item" data-name={item.name.toLowerCase()} data-category={item.category}>
                    <MenuCard 
                        id={item.id} name={item.name} description={item.description} 
                        price={item.price} image={item.image} category={item.category}
                        prices={item.prices} type={item.type}
                    />
                </div>
            ))}
        </div>

        <div id="no-pizza-results" class="hidden text-center py-20">
            <p class="text-neutral-500 text-lg">No encontramos pizzas con ese nombre.</p>
            <button onclick="document.getElementById('pizza-search').value = ''; document.getElementById('pizza-search').dispatchEvent(new Event('input'));" class="text-amber-600 hover:underline mt-2">Borrar búsqueda</button>
        </div>
    </div>

    {/* --- SECCIÓN SUCURSALES --- */}
    <div id="sucursales" class="relative z-20 mt-12 md:mt-20">
       <Sucursales />
    </div>

  </main>
  <ProductModal client:load />
</Layout>

<style>
    /* Estilos */
    .cat-btn {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.75rem; 
        font-weight: bold;
        text-transform: uppercase;
        color: #737373;
        border: 1px solid rgba(0,0,0,0.1); 
        transition: all 0.3s ease;
        white-space: nowrap;
    }
    @media (min-width: 768px) {
        .cat-btn { font-size: 0.8rem; padding: 8px 16px; }
    }
    .cat-btn:hover { color: #171717; border-color: rgba(0,0,0,0.3); }
    .cat-btn.active {
        background-color: #f59e0b;
        color: #171717;
        border-color: #f59e0b;
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.2);
    }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .mask-fade-right {
        -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
        mask-image: linear-gradient(to right, black 85%, transparent 100%);
    }
</style>

<script>
  import { selectedGlobalSize } from '../stores/cartStore.js';

  function initAppLogic() {
    const screenSizes = document.getElementById('screen-sizes');
    const screenFlavors = document.getElementById('screen-flavors');
    
    const displaySize = document.getElementById('display-selected-size');
    const btnBackSizes = document.getElementById('btn-back-sizes');
    const btnBackHome = document.getElementById('btn-back-home');

    // --- 1. FUNCIÓN PARA CAMBIAR PANTALLAS ---
    const showScreen = (screenId, shouldScrollTop = true) => {
        [screenSizes, screenFlavors].forEach(s => {
            if (s) {
                s.classList.add('hidden', 'opacity-0', 'pointer-events-none');
                s.classList.remove('translate-x-0', 'translate-y-0');
            }
        });

        const target = document.getElementById(screenId);
        if (target) {
            target.classList.remove('hidden');
            setTimeout(() => {
                target.classList.remove('opacity-0', 'pointer-events-none');
                target.classList.add('translate-x-0', 'translate-y-0');
                
                if (shouldScrollTop) {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
            }, 50);
        }
    };

    // --- 2. CEREBRO DE NAVEGACIÓN ---
    const handleNavigation = () => {
        const hash = window.location.hash;

        // CASO 1: Paquetes o Snacks
        if (hash === '#paquetes' || hash === '#snacks') {
            selectedGlobalSize.set(null);
            
            showScreen('screen-sizes', false); // No saltar arriba
            
            setTimeout(() => {
                const extrasSection = document.getElementById('extras-grid');
                if(extrasSection) {
                    // Calculamos la posición y le restamos un poco para que no quede pegado al borde
                    const y = extrasSection.getBoundingClientRect().top + window.scrollY - 180;
                    window.scrollTo({ top: y, behavior: 'smooth' });
                }
                
                const filterTerm = hash === '#paquetes' ? 'Paquetes' : 'Snacks';
                const btn = document.querySelector(`.extra-cat-btn[data-filter="${filterTerm}"]`);
                if(btn) btn.click();
            }, 100);

        } 
        // CASO 2: Menú normal
        else if (hash === '#menu' || hash === '#pizzas-especialidad') {
            selectedGlobalSize.set(null); 
            showScreen('screen-sizes', true);
        } 
    };

    window.addEventListener('hashchange', handleNavigation);
    if(window.location.hash) {
        setTimeout(handleNavigation, 100);
    }

    // --- 3. LÓGICA DE STORE ---
    selectedGlobalSize.subscribe(size => {
        const hash = window.location.hash;
        if(hash === '#paquetes' || hash === '#snacks') return; 

        if (size) {
            if(displaySize) displaySize.textContent = size;
            showScreen('screen-flavors', true);
        } else {
            if(hash !== '#menu') {
                 showScreen('screen-sizes', true);
            }
        }
    });

    // --- 4. BOTONES ---
    btnBackSizes?.addEventListener('click', () => {
        history.pushState("", document.title, window.location.pathname + window.location.search);
        selectedGlobalSize.set(null);
        showScreen('screen-sizes', true);
    });

    btnBackHome?.addEventListener('click', () => {
        history.pushState("", document.title, window.location.pathname + window.location.search);
        selectedGlobalSize.set(null);
        showScreen('screen-sizes', true);
    });

    // --- 5. BÚSQUEDA ---
    const searchInput = document.getElementById('pizza-search');
    const catButtons = document.querySelectorAll('.cat-btn');
    const pizzaItems = document.querySelectorAll('.pizza-item');
    const noResults = document.getElementById('no-pizza-results');
    let currentFilter = 'all';

    const filterPizzas = () => {
        if (!(searchInput instanceof HTMLInputElement)) return;
        const term = searchInput.value.toLowerCase();
        let count = 0;

        pizzaItems.forEach(item => {
            const name = item.getAttribute('data-name');
            const category = item.getAttribute('data-category');
            const matchesSearch = name && name.includes(term);
            const matchesCat = currentFilter === 'all' || category === currentFilter;

            if (matchesSearch && matchesCat) {
                item.classList.remove('hidden');
                count++;
            } else {
                item.classList.add('hidden');
            }
        });
        if(noResults) noResults.style.display = count === 0 ? 'block' : 'none';
    };

    if (searchInput) searchInput.addEventListener('input', filterPizzas);

    catButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            catButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentFilter = btn.getAttribute('data-filter') || 'all';
            filterPizzas();
        });
    });

    // --- 6. FILTROS EXTRAS ---
    const extraButtons = document.querySelectorAll('.extra-cat-btn');
    const extraItems = document.querySelectorAll('.extra-item');

    extraButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            extraButtons.forEach(b => {
                b.classList.remove('bg-amber-500', 'text-black', 'border-amber-500');
                b.classList.add('text-neutral-500', 'border-black/10');
            });
            btn.classList.remove('text-neutral-500', 'border-black/10');
            btn.classList.add('bg-amber-500', 'text-black', 'border-amber-500');

            const filter = btn.getAttribute('data-filter');
            extraItems.forEach(item => {
                if(filter === 'Todos' || item.getAttribute('data-category') === filter) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });
        });
    });

    if(!window.location.hash && extraButtons.length > 0) {
        const firstBtn = extraButtons[0];
        if(firstBtn instanceof HTMLElement) firstBtn.click();
    }
  }

  document.addEventListener('astro:page-load', initAppLogic);
  document.addEventListener('DOMContentLoaded', initAppLogic);
</script>